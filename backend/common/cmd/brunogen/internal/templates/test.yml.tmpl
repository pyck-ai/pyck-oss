settings:
  encodeUrl: true
  timeout: 5000
  followRedirects: true
  maxRedirects: 5


{{- define "variables"}}
{{- if .Vars}}
    variables: |-
      // Code generated by github.com/pyck-ai/pyck/backend/common/cmd/brunogen. DO NOT EDIT.
      {{- if .SourceFile}}
      // Source: {{.SourceFile}}
      {{- end}}

{{ .Vars | marshalVars | indent 6 }}
{{- end}}
{{- end}}


{{- define "deletevar:code"}}
{{- range .Extracts}}
        bru.deleteVar('{{.VarName}}');
{{- end}}
{{- end}}


{{- define "skip:code"}}
{{- range .SkipChecks}}
{{- range .Expects}}
        try { expect({{.Subject}}){{.Assertion}}; bru.runner.skipRequest(); } catch(e) {}
{{- end}}
{{- end}}
{{- end}}


{{- define "tests:code"}}
{{- if .UseBody}}

        var body = res.body;
{{- end}}
{{- if .UseVars}}
        var vars = req.body.variables;
{{- end}}
{{- range .Tests}}

        test({{.QuotedName}}, function() {
{{- range .Expects}}
{{- if .Wildcard}}
          {{.ArrayExpr}}?.forEach(function(item) {
            expect(item?.{{.ItemPath}}){{.ItemAssert}};
          });
{{- else}}
          expect({{.Subject}}){{.Assertion}};
{{- end}}
{{- end}}
        });
{{- end}}
{{- end}}


{{- define "afterrequest:code"}}
{{- if .ExtractsNeedBody}}

        var body = res.body;
{{- end}}
{{- if .ExtractsNeedVars}}
        var vars = req.body.variables;
{{- end}}
{{- range .Extracts}}
        bru.setVar('{{.VarName}}', {{.Expr}});
{{- end}}
{{- end}}

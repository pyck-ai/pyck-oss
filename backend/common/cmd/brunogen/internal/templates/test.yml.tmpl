runtime:
  scripts:
{{- if or .SkipChecks .Extracts}}
    - type: before-request
      code: |-
{{- if .Extracts}}
{{- template "deletevar:code" .}}
{{- end}}
{{- if .SkipChecks}}
{{- template "skip:code" .}}
{{- end}}
{{- end}}

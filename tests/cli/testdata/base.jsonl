{"__typename": "DataType", "name": "Default Customer", "slug": "default-customer", "entity": "Customer", "default": true, "jsonSchema": "{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"code\":{\"type\":\"string\"},\"address\":{\"type\":\"string\"}}}"}
